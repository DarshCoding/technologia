# --- Backend ---
APP_NAME=Technologia
APP_ENV=development
DEBUG=true

# Database
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=technologia
MYSQL_USER=app
MYSQL_PASSWORD=app_password
MYSQL_ROOT_PASSWORD=root_password
DATABASE_URL=mysql+aiomysql://app:app_password@mysql:3306/technologia

# Auth (override SECRET_KEY in production!)
SECRET_KEY=change-me-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_ALGORITHM=HS256

# CORS (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Bootstrap admin (seeded on first boot if no users exist)
FIRST_ADMIN_EMAIL=admin@technologia.dev
FIRST_ADMIN_PASSWORD=admin123
FIRST_ADMIN_NAME=Administrator

# --- Frontend ---
VITE_API_URL=http://localhost:8000
